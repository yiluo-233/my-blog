---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ id }) => id.startsWith('journal/')))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="日记" description="日记列表" />
  </head>
  <body>
    <Header />
    <main>
      <h2>日记</h2>
      <ul>
        {posts.map(post => (
          <li>
            <a href={`/blog/${post.id.replace('.md', '')}`}>{post.data.title}</a>
            <span>{post.data.pubDate.toLocaleDateString('zh-CN')}</span>
          </li>
        ))}
      </ul>
    </main>
    <Footer />
  </body>
</html>

<style>
body {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
}

main {
  flex: 1;
}
  main {
    max-width: 720px;
    margin: 0 auto;
    padding: 3em 1em;
  }
  h2 {
    color: #c084a0;
    margin-bottom: 1.5em;
  }
  ul {
    list-style: none;
    padding: 0;
  }
  li {
    display: flex;
    justify-content: space-between;
    padding: 0.8em 0;
    border-bottom: 1px solid rgba(192, 132, 160, 0.2);
  }
  a {
    color: rgb(var(--gray-dark));
    text-decoration: none;
  }
  a:hover {
    color: #c084a0;
  }
  span {
    color: rgb(var(--gray));
    font-size: 0.9em;
  }
</style>
