---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---
<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<div class="hero">
				<h1>My Blog</h1>
				<p>Hello.</p>
			</div>
		</main>
<div class="social-links">
    <a href="https://x.com/yiluo_928" target="_blank">Twitter / X</a>
    <a href="https://space.bilibili.com/1475463692" target="_blank">哔哩哔哩</a>
    <a href="https://github.com/yiluo-233" target="_blank">GitHub</a>
    <a href="https://www.jianshu.com/u/1814a1f0ae33" target="_blank">简书</a>
</div>
		<Footer />
	</body>
</html>
<style>
.social-links {
    display: flex;
    justify-content: center;
    gap: 1.5em;
    padding: 2em 0 0;
}
.social-links a {
    color: rgb(var(--gray));
    text-decoration: none;
    font-size: 0.9em;
    letter-spacing: 0.05em;
}
.social-links a:hover {
    color: #c084a0;
}
	.hero {
		text-align: center;
		padding: 100px 20px 40px;
	}
	.hero h1 {
		font-size: 3rem;
		margin-bottom: 60px;
		color: #c084a0;
	}
	.hero p {
		font-size: 1.8rem;
		color: #888;
		letter-spacing: 0.1em;
	}
</style>
