---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---
<!doctype html>
<html lang="en">
  <head>
    <BaseHead title="Blog" description="文章列表" />
  </head>
  <body>
    <Header />
    <main>
      <div class="categories">
        <a href="/blog/essay">散文</a>
        <a href="/blog/journal">日记</a>
      </div>
    </main>
    <Footer />
  </body>
</html>
<style>
  .categories {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5em;
    padding: 4em 1em;
  }
  .categories a {
    font-size: 1.5rem;
    color: #c084a0;
    text-decoration: none;
    letter-spacing: 0.1em;
  }
  .categories a:hover {
    opacity: 0.7;
  }
</style>
